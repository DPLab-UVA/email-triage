#!/bin/zsh
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
PYTHON_BIN="$ROOT/.venv/bin/python"

if [[ ! -x "$PYTHON_BIN" ]]; then
  echo "Missing Gmail skill virtualenv: $ROOT/.venv" >&2
  echo "Create it with: /opt/homebrew/bin/python3 -m venv '$ROOT/.venv' && '$ROOT/.venv/bin/pip' install google-api-python-client google-auth-httplib2 google-auth-oauthlib" >&2
  exit 1
fi

exec "$PYTHON_BIN" "$ROOT/scripts/gmail_api_mail.py" "$@"
