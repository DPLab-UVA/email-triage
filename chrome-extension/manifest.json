{
  "manifest_version": 3,
  "name": "Outlook Web Triage Prototype",
  "version": "0.1.3",
  "description": "Best-effort DOM-based triage for Outlook Webmail. Extracts visible message metadata, scores importance, and drafts reply guidance.",
  "action": {
    "default_title": "Outlook Triage",
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*",
    "https://outlook.office.com/*",
    "https://outlook.live.com/*",
    "https://outlook.office365.com/*",
    "https://outlook.cloud.microsoft/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://outlook.office.com/*",
        "https://outlook.live.com/*",
        "https://outlook.office365.com/*",
        "https://outlook.cloud.microsoft/*"
      ],
      "js": [
        "triage-core.js",
        "dom-extract.js",
        "content-script.js"
      ],
      "css": [
        "content-style.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Toggle the Outlook triage panel"
    }
  }
}
